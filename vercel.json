{
  "version": 2,
  "builds": [
    {
      "src": "itp_frontend/next.config.ts",
      "use": "@vercel/next",
      "config": {
        "distDir": ".next"
      }
    },
    {
      "src": "src/main.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["dist/**"]
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/src/main.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/itp_frontend/$1"
    }
  ]
}
