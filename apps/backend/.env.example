# ─── Copie este arquivo para .env e preencha os valores ───────────────────────
# cp .env.example .env

# Conexão com o Banco (Neon ou PostgreSQL local)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Segredo JWT (gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=COLOQUE_UM_SEGREDO_FORTE_AQUI

# URL do frontend (usada em links de e-mail LGPD)
APP_URL=https://itp.institutotiapretinha.org

# ─── SMTP (Envio de e-mails) ──────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seuemail@gmail.com
SMTP_PASS=sua_senha_de_app_gmail
SMTP_FROM=Instituto Tia Pretinha <seuemail@gmail.com>
