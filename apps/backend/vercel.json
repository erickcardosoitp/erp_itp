{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/server.js": {
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "dist/**"
    },
    "api/health.ts": {
      "memory": 128,
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "^/$",
      "headers": { "Location": "https://api.itp.institutotiapretinha.org/api" },
      "status": 308
    },
    {
      "src": "/health",
      "dest": "/api/health.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/api/server.js"
    }
  ]
}
