{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": {
    "COLETOR_TOKEN": "itp-coletor-2026",
    "NEXT_PUBLIC_COLETOR_TOKEN": "itp-coletor-2026",
    "CHAMADA_TOKEN": "itp-chamada-2026",
    "NEXT_PUBLIC_CHAMADA_TOKEN": "itp-chamada-2026"
  },
  "functions": {
    "api/main.ts": {
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "dist/**"
    },
    "api/health.ts": {
      "memory": 128,
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "^/$",
      "headers": { "Location": "https://api.itp.institutotiapretinha.org/api" },
      "status": 308
    },
    {
      "src": "/health",
      "dest": "/api/health.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/api/main.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/auth/cron/verificar-senhas",
      "schedule": "0 8 * * *"
    }
  ]
}
