{
  "version": 2,
  "buildCommand": "npm ci && rm -f tsconfig.tsbuildinfo && npm run build",
  "outputDirectory": "dist",
  "env": {
    "COLETOR_TOKEN": "itp-coletor-2026",
    "NEXT_PUBLIC_COLETOR_TOKEN": "itp-coletor-2026",
    "CHAMADA_TOKEN": "itp-chamada-2026",
    "NEXT_PUBLIC_CHAMADA_TOKEN": "itp-chamada-2026"
  },
  "functions": {
    "api/main.ts": {
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": "dist/**"
    },
    "api/health.ts": {
      "memory": 128,
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://institutotiapretinha.org" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,HEAD,PUT,PATCH,POST,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type,Authorization,Accept,Cookie,X-Requested-With" },
        { "key": "Access-Control-Allow-Credentials", "value": "true" }
      ]
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "headers": { "Location": "https://api.itp.institutotiapretinha.org/api" },
      "status": 308
    },
    {
      "src": "/health",
      "dest": "/api/health.ts"
    },
    {
      "methods": ["OPTIONS"],
      "src": "/(.*)",
      "status": 204,
      "headers": {
        "Access-Control-Allow-Origin": "https://institutotiapretinha.org",
        "Access-Control-Allow-Methods": "GET,HEAD,PUT,PATCH,POST,DELETE,OPTIONS",
        "Access-Control-Allow-Headers": "Content-Type,Authorization,Accept,Cookie,X-Requested-With",
        "Access-Control-Allow-Credentials": "true",
        "Access-Control-Max-Age": "86400"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/api/main.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/auth/cron/verificar-senhas",
      "schedule": "0 8 * * *"
    }
  ]
}
